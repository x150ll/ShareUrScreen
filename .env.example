# ─────────────────────────────────────────────────────────────
# .env.example — انسخ هذا الملف إلى .env واملأ القيم الحقيقية
# لا ترفع ملف .env أبداً للـ repo
# ─────────────────────────────────────────────────────────────

# ExpressTURN — https://www.expressturn.com
EXPRESSTURN_USERNAME=YOUR_USERNAME_HERE
EXPRESSTURN_CREDENTIAL=YOUR_CREDENTIAL_HERE

# Firebase Project ID (للتوثيق فقط — القيم الحقيقية في google-services.json)
FIREBASE_PROJECT_ID=share-ur-screen
